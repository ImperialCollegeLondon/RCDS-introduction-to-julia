// For format details, see https://aka.ms/devcontainer.json.
{
    "name": "Julia on Pluto",
    "image": "ghcr.io/imperialcollegelondon/rcds-introduction-to-julia-devcontainer:latest",
    "remoteUser": "vscode",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": false
        }
    },
    "onCreateCommand": "julia --project=. -e 'using Pkg; Pkg.instantiate()'",
    "containerEnv": {
        "JULIA_DEPOT_PATH": "/usr/local/julia-depot"
    },
    "postAttachCommand": "julia --project=. -e 'using Pluto; Pluto.run(require_secret_for_open_links=false, require_secret_for_access=false)'",
    "forwardPorts": [1234],
    "portsAttributes": {
        "1234": {
            "label": "Pluto",
            "onAutoForward": "openPreview"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "julialang.language-julia"
            ],
            "settings": {
                "chat.sendElementsToChat.enabled": false,
                "julia.executablePath": "/usr/local/bin/julia",
                "markdown.preview.security.level": "allow-insecure-local-content",
                "julia.additionalArgs": ["--project=."],
                "julia.environmentPath": "${containerWorkspaceFolder}",
                "julia.format.enable": false,
                "julia.lint.run": true,
                "julia.lint.call": false,
                "julia.symbolCacheDownload": false,
                "julia.usePlotPane": false
            }
        }
    }
}
