// For format details, see https://aka.ms/devcontainer.json.
{
    "name": "Julia on Pluto",
    "image": "julia:1.12-bookworm",
    "remoteUser": "vscode",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": false
        }
    },
    "onCreateCommand": "julia --project=. -e 'using Pkg; Pkg.instantiate()'",
    "updateContentCommand": "julia --project=. -e 'using Pkg; Pkg.instantiate()'",
    "postAttachCommand": "setsid julia --project=. -e 'using Pluto, Logging; global_logger(ConsoleLogger(stdout)); @async while true; sleep(300); @info \"keepalive\"; end; Pluto.run(require_secret_for_open_links=false, require_secret_for_access=false)' &",
    "forwardPorts": [1234],
    "portsAttributes": {
        "1234": {
            "label": "Pluto",
            "onAutoForward": "openPreview"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "julialang.language-julia"
            ],
            "settings": {
                "markdown.preview.security.level": "allow-insecure-local-content",
                "julia.additionalArgs": ["--project=."],
                "julia.environmentPath": "${containerWorkspaceFolder}",
                "julia.format.enable": false,
                "julia.lint.run": true,
                "julia.lint.call": false,
                "julia.symbolCacheDownload": false,
                "julia.usePlotPane": false
            }
        }
    }
}
